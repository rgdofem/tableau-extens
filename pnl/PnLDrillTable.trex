<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <worksheet-extension id="com.rgdofem.extensions.pnldrilltable" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>An interactive P&amp;L table with expandable categories, derived budget/prior-year variances, and favorability-colored variance bubbles.</description>
    <author name="rgdofem" email="ryan.goodman@pinnacletreatment.com" organization="rgdofem" website="https://github.com/rgdofem/tableau-extens"/>
    <min-api-version>1.11</min-api-version>
    <source-location>
      <url>https://rgdofem.github.io/tableau-extens/pnl/index.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAACAAAAAgCAYAAABzenr0AAAAAXNSR0IArs4c6QAAAARnQU1BAACxjwv8YQUAAAAJcEhZcwAADsMAAA7DAcdvqGQAAABsSURBVFhH7dShDcAgFEVRxkFV1KA7QgdivW7SIDpE6y95JDUfxLvJM6iT/IT0Ti7xIbp1AHd7QmeAAesBZmVAByjH+Wtsq/twzIAOEJ0BEsBbq7Er5+GYARIQlQESwFurMf58HDNAAqIywIAPwDNbu4wyxI8AAAAASUVORK5CYII=</icon>
    <encoding id="category">
      <display-name resource-id="enc-category">Category</display-name>
      <data-spec>
        <data-type>string</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-c"/>
      <tooltip resource-id="tt-category">The parent P&amp;L line item (Revenue, SG&amp;A, Total Cost of Sales, etc). Required.</tooltip>
    </encoding>
    <encoding id="subcategory">
      <display-name resource-id="enc-subcategory">Subcategory</display-name>
      <data-spec>
        <data-type>string</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-s"/>
      <tooltip resource-id="tt-subcategory">Optional child dimension: subcategory line items revealed when a category is expanded.</tooltip>
    </encoding>
    <encoding id="location">
      <display-name resource-id="enc-location">Location</display-name>
      <data-spec>
        <data-type>string</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="globe"/>
      <tooltip resource-id="tt-location">Optional child dimension: locations revealed when a category is expanded.</tooltip>
    </encoding>
    <encoding id="polarity">
      <display-name resource-id="enc-polarity">Polarity</display-name>
      <data-spec>
        <data-type>string</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="delta-up"/>
      <tooltip resource-id="tt-polarity">Optional: tags each line as revenue-type vs expense-type (or true/false for higher-is-better). Used only for variance color and sign.</tooltip>
    </encoding>
    <encoding id="actual">
      <display-name resource-id="enc-actual">Actual</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="dollar"/>
      <tooltip resource-id="tt-actual">Current-period actual dollars. Required.</tooltip>
    </encoding>
    <encoding id="budget">
      <display-name resource-id="enc-budget">Budget</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-b"/>
      <tooltip resource-id="tt-budget">Optional current-period budget. Enables Budget, Var $, and Var % columns.</tooltip>
    </encoding>
    <encoding id="py">
      <display-name resource-id="enc-py">Prior Year</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-p"/>
      <tooltip resource-id="tt-py">Optional prior-year value. Enables PY and PY Var % columns.</tooltip>
    </encoding>
    <encoding id="ytdactual">
      <display-name resource-id="enc-ytdactual">YTD Actual</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-y"/>
      <tooltip resource-id="tt-ytdactual">Optional year-to-date actual. Enables the YTD Act column.</tooltip>
    </encoding>
    <encoding id="ytdbudget">
      <display-name resource-id="enc-ytdbudget">YTD Budget</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-t"/>
      <tooltip resource-id="tt-ytdbudget">Optional year-to-date budget. With YTD Actual, enables YTD Bdgt, YTD Var $, and YTD Var columns.</tooltip>
    </encoding>
    <encoding id="sortorder">
      <display-name resource-id="enc-sortorder">Sort Order</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="hash"/>
      <tooltip resource-id="tt-sortorder">Optional numeric measure that controls category ordering. If omitted, the incoming row order is kept.</tooltip>
    </encoding>
  </worksheet-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">P&amp;L Drill Table</text>
    </resource>
    <resource id="enc-category">
      <text locale="en_US">Category</text>
    </resource>
    <resource id="enc-subcategory">
      <text locale="en_US">Subcategory</text>
    </resource>
    <resource id="enc-location">
      <text locale="en_US">Location</text>
    </resource>
    <resource id="enc-polarity">
      <text locale="en_US">Polarity</text>
    </resource>
    <resource id="enc-actual">
      <text locale="en_US">Actual</text>
    </resource>
    <resource id="enc-budget">
      <text locale="en_US">Budget</text>
    </resource>
    <resource id="enc-py">
      <text locale="en_US">Prior Year</text>
    </resource>
    <resource id="enc-ytdactual">
      <text locale="en_US">YTD Actual</text>
    </resource>
    <resource id="enc-ytdbudget">
      <text locale="en_US">YTD Budget</text>
    </resource>
    <resource id="enc-sortorder">
      <text locale="en_US">Sort Order</text>
    </resource>
    <resource id="tt-category">
      <text locale="en_US">The parent P&amp;L line item (Revenue, SG&amp;A, Total Cost of Sales, etc). Required.</text>
    </resource>
    <resource id="tt-subcategory">
      <text locale="en_US">Optional child dimension: subcategory line items revealed when a category is expanded.</text>
    </resource>
    <resource id="tt-location">
      <text locale="en_US">Optional child dimension: locations revealed when a category is expanded.</text>
    </resource>
    <resource id="tt-polarity">
      <text locale="en_US">Optional: tags each line as revenue-type vs expense-type (or true/false for higher-is-better). Used only for variance color and sign.</text>
    </resource>
    <resource id="tt-actual">
      <text locale="en_US">Current-period actual dollars. Required.</text>
    </resource>
    <resource id="tt-budget">
      <text locale="en_US">Optional current-period budget. Enables Budget, Var $, and Var % columns.</text>
    </resource>
    <resource id="tt-py">
      <text locale="en_US">Optional prior-year value. Enables PY and PY Var % columns.</text>
    </resource>
    <resource id="tt-ytdactual">
      <text locale="en_US">Optional year-to-date actual. Enables the YTD Act column.</text>
    </resource>
    <resource id="tt-ytdbudget">
      <text locale="en_US">Optional year-to-date budget. With YTD Actual, enables YTD Bdgt, YTD Var $, and YTD Var columns.</text>
    </resource>
    <resource id="tt-sortorder">
      <text locale="en_US">Optional numeric measure that controls category ordering. If omitted, the incoming row order is kept.</text>
    </resource>
  </resources>
</manifest>
