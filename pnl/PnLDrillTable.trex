<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <worksheet-extension id="com.rgdofem.extensions.pnldrilltable" extension-version="1.3.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>An interactive P&amp;L table with expandable categories, derived budget/prior-year variances, favorability-colored variance bubbles, settings-based polarity control, and an optional grand total row.</description>
    <author name="rgdofem" email="ryan.goodman@pinnacletreatment.com" organization="rgdofem" website="https://github.com/rgdofem/tableau-extens"/>
    <min-api-version>1.11</min-api-version>
    <source-location>
      <url>https://rgdofem.github.io/tableau-extens/pnl/index.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAACAAAAAgCAYAAABzenr0AAAAAXNSR0IArs4c6QAAAARnQU1BAACxjwv8YQUAAAAJcEhZcwAADsMAAA7DAcdvqGQAAABsSURBVFhH7dShDcAgFEVRxkFV1KA7QgdivW7SIDpE6y95JDUfxLvJM6iT/IT0Ti7xIbp1AHd7QmeAAesBZmVAByjH+Wtsq/twzIAOEJ0BEsBbq7Er5+GYARIQlQESwFurMf58HDNAAqIywIAPwDNbu4wyxI8AAAAASUVORK5CYII=</icon>
    <encoding id="category">
      <display-name resource-id="enc-category">Category</display-name>
      <data-spec>
        <data-type>string</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="letter-c"/>
      <tooltip resource-id="tt-category">The parent P&amp;L line item (Revenue, SG&amp;A, Total Cost of Sales, etc). Required.</tooltip>
    </encoding>
    <encoding id="drilldim">
      <display-name resource-id="enc-drilldim">Drill To</display-name>
      <data-spec>
        <data-type>string</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="2"/>
      <encoding-icon token="level"/>
      <tooltip resource-id="tt-drilldim">Child dimensions revealed when a category expands (e.g. Subcategory and/or Location). Drop up to two; the header switcher toggles between them.</tooltip>
    </encoding>
    <encoding id="polarity">
      <display-name resource-id="enc-polarity">Polarity</display-name>
      <data-spec>
        <data-type>string</data-type>
        <data-type>boolean</data-type>
      </data-spec>
      <role-spec>
        <role-type>discrete-dimension</role-type>
      </role-spec>
      <fields max-count="1"/>
      <encoding-icon token="delta-up"/>
      <tooltip resource-id="tt-polarity">Optional: tags each line as revenue-type vs expense-type (or true/false for higher-is-better). Used only for variance color and sign.</tooltip>
    </encoding>
    <encoding id="measures">
      <display-name resource-id="enc-measures">Measures</display-name>
      <data-spec>
        <data-type>numeric</data-type>
      </data-spec>
      <role-spec>
        <role-type>continuous-measure</role-type>
      </role-spec>
      <fields max-count="6"/>
      <encoding-icon token="dollar"/>
      <tooltip resource-id="tt-measures">Up to six measures: Actual (required), Budget, Prior Year, YTD Actual, YTD Budget, Sort Order. Roles are auto-detected from field names and can be reassigned in the settings dialog.</tooltip>
    </encoding>
  </worksheet-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">P&amp;L Drill Table</text>
    </resource>
    <resource id="enc-category">
      <text locale="en_US">Category</text>
    </resource>
    <resource id="enc-drilldim">
      <text locale="en_US">Drill To</text>
    </resource>
    <resource id="enc-polarity">
      <text locale="en_US">Polarity</text>
    </resource>
    <resource id="enc-measures">
      <text locale="en_US">Measures</text>
    </resource>
    <resource id="tt-category">
      <text locale="en_US">The parent P&amp;L line item (Revenue, SG&amp;A, Total Cost of Sales, etc). Required.</text>
    </resource>
    <resource id="tt-drilldim">
      <text locale="en_US">Child dimensions revealed when a category expands (e.g. Subcategory and/or Location). Drop up to two; the header switcher toggles between them.</text>
    </resource>
    <resource id="tt-polarity">
      <text locale="en_US">Optional: tags each line as revenue-type vs expense-type (or true/false for higher-is-better). Used only for variance color and sign.</text>
    </resource>
    <resource id="tt-measures">
      <text locale="en_US">Up to six measures: Actual (required), Budget, Prior Year, YTD Actual, YTD Budget, Sort Order. Roles are auto-detected from field names and can be reassigned in the settings dialog.</text>
    </resource>
  </resources>
</manifest>
